{
  "type": "shadowsocks",
  "label": "Shadowsocks",
  "fields": [
    {
      "key": "tag",
      "label": "Tag",
      "kind": "string",
      "required": true
    },
    {
      "key": "server",
      "label": "服务器地址",
      "kind": "string",
      "required": true
    },
    {
      "key": "server_port",
      "label": "服务器端口",
      "kind": "number",
      "required": true,
      "min": 1,
      "max": 65535,
      "defaultValue": 8388
    },
    {
      "key": "method",
      "label": "Method",
      "kind": "select",
      "required": true,
      "options": [
        "2022-blake3-aes-128-gcm",
        "2022-blake3-aes-256-gcm",
        "2022-blake3-chacha20-poly1305",
        "none",
        "aes-128-gcm",
        "aes-192-gcm",
        "aes-256-gcm",
        "chacha20-ietf-poly1305",
        "xchacha20-ietf-poly1305",
        "aes-128-ctr",
        "aes-192-ctr",
        "aes-256-ctr",
        "aes-128-cfb",
        "aes-192-cfb",
        "aes-256-cfb",
        "rc4-md5",
        "chacha20-ietf",
        "xchacha20"
      ],
      "defaultValue": "2022-blake3-aes-128-gcm"
    },
    {
      "key": "password",
      "label": "密码",
      "kind": "string",
      "required": true
    },
    {
      "key": "plugin",
      "label": "Plugin",
      "kind": "string"
    },
    {
      "key": "plugin_opts",
      "label": "Plugin opts",
      "kind": "string"
    },
    {
      "key": "network",
      "label": "网络",
      "kind": "select",
      "options": [
        "",
        "tcp",
        "udp"
      ]
    },
    {
      "key": "udp_over_tcp",
      "label": "UDP over TCP",
      "kind": "object",
      "wide": true,
      "fields": [
        {
          "key": "enabled",
          "label": "启用",
          "kind": "boolean",
          "defaultValue": true
        },
        {
          "key": "version",
          "label": "version",
          "kind": "number",
          "min": 1,
          "max": 2
        }
      ],
      "defaultValue": {
        "enabled": true
      },
      "visibleWhen": [
        {
          "key": "multiplex",
          "op": "empty"
        }
      ]
    },
    {
      "key": "multiplex",
      "label": "Multiplex",
      "kind": "object",
      "wide": true,
      "fields": [
        {
          "key": "enabled",
          "label": "启用",
          "kind": "boolean",
          "defaultValue": true
        },
        {
          "key": "protocol",
          "label": "协议",
          "kind": "select",
          "options": [
            "",
            "smux",
            "yamux",
            "h2mux"
          ]
        },
        {
          "key": "max_connections",
          "label": "最大连接数",
          "kind": "number",
          "min": 0,
          "visibleWhen": [
            {
              "key": "max_streams",
              "op": "empty"
            }
          ]
        },
        {
          "key": "min_streams",
          "label": "最小 streams",
          "kind": "number",
          "min": 0,
          "visibleWhen": [
            {
              "key": "max_streams",
              "op": "empty"
            }
          ]
        },
        {
          "key": "max_streams",
          "label": "最大 streams",
          "kind": "number",
          "min": 0,
          "visibleWhen": [
            {
              "key": "max_connections",
              "op": "empty"
            },
            {
              "key": "min_streams",
              "op": "empty"
            }
          ]
        },
        {
          "key": "padding",
          "label": "padding",
          "kind": "boolean"
        },
        {
          "key": "brutal",
          "label": "Brutal",
          "kind": "object",
          "wide": true,
          "fields": [
            {
              "key": "enabled",
              "label": "启用",
              "kind": "boolean"
            },
            {
              "key": "up_mbps",
              "label": "上行 Mbps",
              "kind": "number",
              "min": 0
            },
            {
              "key": "down_mbps",
              "label": "下行 Mbps",
              "kind": "number",
              "min": 0
            }
          ]
        }
      ],
      "defaultValue": {
        "enabled": true
      },
      "visibleWhen": [
        {
          "key": "udp_over_tcp",
          "op": "empty"
        }
      ]
    },
    {
      "key": "_dialer",
      "label": "拨号字段",
      "kind": "object",
      "wide": true,
      "fields": [
        {
          "key": "detour",
          "label": "拨号 detour",
          "kind": "string"
        },
        {
          "key": "bind_interface",
          "label": "绑定接口",
          "kind": "string",
          "visibleWhen": [
            {
              "key": "detour",
              "op": "empty"
            },
            {
              "key": "network_strategy",
              "op": "empty"
            }
          ]
        },
        {
          "key": "inet4_bind_address",
          "label": "IPv4 绑定地址",
          "kind": "string",
          "visibleWhen": [
            {
              "key": "detour",
              "op": "empty"
            },
            {
              "key": "network_strategy",
              "op": "empty"
            }
          ]
        },
        {
          "key": "inet6_bind_address",
          "label": "IPv6 绑定地址",
          "kind": "string",
          "visibleWhen": [
            {
              "key": "detour",
              "op": "empty"
            },
            {
              "key": "network_strategy",
              "op": "empty"
            }
          ]
        },
        {
          "key": "bind_address_no_port",
          "label": "绑定地址不含端口",
          "kind": "boolean",
          "visibleWhen": [
            {
              "key": "detour",
              "op": "empty"
            },
            {
              "key": "network_strategy",
              "op": "empty"
            }
          ]
        },
        {
          "key": "protect_path",
          "label": "protect_path",
          "kind": "string",
          "visibleWhen": [
            {
              "key": "detour",
              "op": "empty"
            }
          ]
        },
        {
          "key": "routing_mark",
          "label": "routing_mark",
          "kind": "string",
          "visibleWhen": [
            {
              "key": "detour",
              "op": "empty"
            }
          ]
        },
        {
          "key": "reuse_addr",
          "label": "reuse_addr",
          "kind": "boolean",
          "visibleWhen": [
            {
              "key": "detour",
              "op": "empty"
            }
          ]
        },
        {
          "key": "netns",
          "label": "netns",
          "kind": "string",
          "visibleWhen": [
            {
              "key": "detour",
              "op": "empty"
            }
          ]
        },
        {
          "key": "connect_timeout",
          "label": "连接超时",
          "kind": "string",
          "placeholder": "5s",
          "visibleWhen": [
            {
              "key": "detour",
              "op": "empty"
            }
          ]
        },
        {
          "key": "tcp_fast_open",
          "label": "TCP Fast Open",
          "kind": "boolean",
          "visibleWhen": [
            {
              "key": "detour",
              "op": "empty"
            }
          ]
        },
        {
          "key": "tcp_multi_path",
          "label": "TCP Multi Path",
          "kind": "boolean",
          "visibleWhen": [
            {
              "key": "detour",
              "op": "empty"
            }
          ]
        },
        {
          "key": "disable_tcp_keep_alive",
          "label": "禁用 TCP keepalive",
          "kind": "boolean",
          "visibleWhen": [
            {
              "key": "detour",
              "op": "empty"
            }
          ]
        },
        {
          "key": "tcp_keep_alive",
          "label": "TCP keepalive",
          "kind": "string",
          "visibleWhen": [
            {
              "key": "detour",
              "op": "empty"
            }
          ]
        },
        {
          "key": "tcp_keep_alive_interval",
          "label": "TCP keepalive 间隔",
          "kind": "string",
          "visibleWhen": [
            {
              "key": "detour",
              "op": "empty"
            }
          ]
        },
        {
          "key": "udp_fragment",
          "label": "UDP fragment",
          "kind": "boolean",
          "visibleWhen": [
            {
              "key": "detour",
              "op": "empty"
            }
          ]
        },
        {
          "key": "domain_resolver",
          "label": "Domain resolver",
          "kind": "string-or-object",
          "wide": true,
          "fields": [
            {
              "key": "server",
              "label": "服务器",
              "kind": "string",
              "required": true
            },
            {
              "key": "timeout",
              "label": "超时",
              "kind": "string"
            },
            {
              "key": "strategy",
              "label": "策略",
              "kind": "select",
              "options": [
                "",
                "as_is",
                "prefer_ipv4",
                "prefer_ipv6",
                "ipv4_only",
                "ipv6_only"
              ]
            },
            {
              "key": "disable_cache",
              "label": "禁用缓存",
              "kind": "boolean"
            },
            {
              "key": "disable_optimistic_cache",
              "label": "禁用乐观缓存",
              "kind": "boolean"
            },
            {
              "key": "rewrite_ttl",
              "label": "rewrite_ttl",
              "kind": "number",
              "min": 0
            },
            {
              "key": "client_subnet",
              "label": "client_subnet",
              "kind": "string"
            }
          ],
          "visibleWhen": [
            {
              "key": "detour",
              "op": "empty"
            }
          ]
        },
        {
          "key": "network_strategy",
          "label": "网络策略",
          "kind": "select",
          "options": [
            "",
            "default",
            "fallback",
            "hybrid"
          ],
          "visibleWhen": [
            {
              "key": "detour",
              "op": "empty"
            },
            {
              "key": "bind_interface",
              "op": "empty"
            },
            {
              "key": "inet4_bind_address",
              "op": "empty"
            },
            {
              "key": "inet6_bind_address",
              "op": "empty"
            }
          ]
        },
        {
          "key": "network_type",
          "label": "网络类型",
          "kind": "string-list",
          "allowedValues": [
            "wifi",
            "cellular",
            "ethernet",
            "other"
          ],
          "visibleWhen": [
            {
              "key": "detour",
              "op": "empty"
            }
          ]
        },
        {
          "key": "fallback_network_type",
          "label": "fallback 网络类型",
          "kind": "string-list",
          "allowedValues": [
            "wifi",
            "cellular",
            "ethernet",
            "other"
          ],
          "visibleWhen": [
            {
              "key": "detour",
              "op": "empty"
            },
            {
              "key": "network_strategy",
              "op": "equals",
              "value": "fallback"
            }
          ]
        },
        {
          "key": "fallback_delay",
          "label": "fallback delay",
          "kind": "string",
          "visibleWhen": [
            {
              "key": "detour",
              "op": "empty"
            }
          ]
        },
        {
          "key": "domain_strategy",
          "label": "domain_strategy",
          "kind": "select",
          "options": [
            "",
            "as_is",
            "prefer_ipv4",
            "prefer_ipv6",
            "ipv4_only",
            "ipv6_only"
          ],
          "visibleWhen": [
            {
              "key": "detour",
              "op": "empty"
            }
          ]
        }
      ]
    }
  ]
}
