{
  "type": "remote",
  "label": "Remote",
  "fields": [
    {
      "key": "tag",
      "label": "Tag",
      "kind": "string",
      "required": true
    },
    {
      "key": "format",
      "label": "格式",
      "kind": "select",
      "options": ["", "source", "binary"]
    },
    {
      "key": "url",
      "label": "URL",
      "kind": "string",
      "required": true
    },
    {
