        {
          "key": "download_detour",
          "op": "empty"
        }
      ]
    },
    {
      "key": "update_interval",
      "label": "更新间隔",
      "kind": "string",
      "placeholder": "1d"
    },
    {
      "key": "download_detour",
      "label": "下载 detour",
      "kind": "string",
