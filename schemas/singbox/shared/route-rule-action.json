      {
        "key": "network_strategy",
        "op": "empty"
      }
    ]
  },
  {
    "key": "protect_path",
    "label": "protect_path",
    "kind": "string",
    "visibleWhen": [
      {
        "key": "action",
        "op": "equals",
        "value": "direct"
      }
    ]
  },
  {
    "key": "routing_mark",
    "label": "routing_mark",
    "kind": "string-or-number",
    "visibleWhen": [
      {
        "key": "action",
        "op": "equals",
        "value": "direct"
      }
    ]
  },
  {
    "key": "reuse_addr",
    "label": "reuse_addr",
    "kind": "boolean",
    "visibleWhen": [
      {
        "key": "action",
        "op": "equals",
        "value": "direct"
      }
    ]
  },
  {
    "key": "netns",
    "label": "netns",
    "kind": "string",
    "visibleWhen": [
      {
        "key": "action",
        "op": "equals",
        "value": "direct"
      }
    ]
  },
  {
    "key": "connect_timeout",
    "label": "连接超时",
