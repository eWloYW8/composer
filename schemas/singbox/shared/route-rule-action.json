        "value": "direct"
      }
    ]
  },
  {
    "key": "udp_fragment",
    "label": "UDP fragment",
    "kind": "boolean",
    "visibleWhen": [
      {
        "key": "action",
        "op": "equals",
        "value": "direct"
      }
    ]
  },
  {
    "key": "domain_resolver",
    "label": "Domain resolver",
    "kind": "string-or-object",
    "wide": true,
    "ref": "shared/dns-route-options.json",
    "visibleWhen": [
      {
        "key": "action",
        "op": "equals",
        "value": "direct"
      }
    ]
  },
  {
    "key": "network_strategy",
    "label": "网络策略",
    "kind": "select",
    "options": ["", "default", "fallback", "hybrid"],
    "visibleWhen": [
      {
        "key": "action",
        "op": "equals",
        "value": "direct"
      },
      {
        "key": "bind_interface",
        "op": "empty"
      },
      {
        "key": "inet4_bind_address",
        "op": "empty"
      },
      {
        "key": "inet6_bind_address",
        "op": "empty"
      }
    ]
  },
  {
    "key": "network_type",
    "label": "网络类型",
    "kind": "string-list",
    "allowedValues": ["wifi", "cellular", "ethernet", "other"],
    "visibleWhen": [
      {
        "key": "action",
        "op": "equals",
        "value": "direct"
      }
    ]
  },
  {
    "key": "fallback_network_type",
    "label": "fallback 网络类型",
    "kind": "string-list",
    "allowedValues": ["wifi", "cellular", "ethernet", "other"],
    "visibleWhen": [
      {
        "key": "action",
        "op": "equals",
        "value": "direct"
      },
      {
        "key": "network_strategy",
        "op": "equals",
        "value": "fallback"
      }
    ]
  },
  {
    "key": "fallback_delay",
    "label": "fallback delay",
    "kind": "string",
    "visibleWhen": [
      {
        "key": "action",
        "op": "equals",
        "value": "direct"
      }
    ]
  },
  {
    "key": "domain_strategy",
    "label": "domain_strategy",
    "kind": "select",
    "options": [
      "",
      "as_is",
      "prefer_ipv4",
      "prefer_ipv6",
      "ipv4_only",
      "ipv6_only"
    ],
    "visibleWhen": [
      {
        "key": "action",
        "op": "equals",
        "value": "direct"
      }
    ]
  },
  {
    "key": "method",
    "label": "拒绝方式",
    "kind": "select",
    "options": ["", "default", "drop", "reply"],
    "visibleWhen": [
      {
        "key": "action",
        "op": "equals",
        "value": "reject"
      }
    ]
  },
  {
    "key": "no_drop",
    "label": "不自动丢弃",
    "kind": "boolean",
    "visibleWhen": [
      {
        "key": "action",
        "op": "equals",
        "value": "reject"
      },
      {
        "key": "method",
        "op": "not-equals",
        "value": "drop"
      }
    ]
  },
  {
    "key": "sniffer",
    "label": "探测器",
    "kind": "string-list",
    "allowedValues": ["tls", "http", "quic", "stun", "dns", "bittorrent", "ssh", "rdp"],
    "visibleWhen": [
      {
        "key": "action",
        "op": "equals",
        "value": "sniff"
      }
    ]
  },
  {
    "key": "timeout",
    "label": "超时",
    "kind": "string",
    "visibleWhen": [
      {
        "key": "action",
        "op": "one-of",
        "values": ["sniff", "resolve"]
      }
    ]
  },
  {
    "key": "server",
    "label": "DNS 服务器",
    "kind": "string",
    "visibleWhen": [
      {
        "key": "action",
        "op": "equals",
        "value": "resolve"
      }
    ]
  },
  {
    "key": "strategy",
    "label": "解析策略",
    "kind": "select",
    "options": ["", "as_is", "prefer_ipv4", "prefer_ipv6", "ipv4_only", "ipv6_only"],
    "visibleWhen": [
      {
        "key": "action",
        "op": "equals",
        "value": "resolve"
      }
    ]
  },
  {
    "key": "disable_cache",
    "label": "禁用缓存",
    "kind": "boolean",
    "visibleWhen": [
      {
        "key": "action",
        "op": "equals",
        "value": "resolve"
      }
    ]
  },
  {
    "key": "disable_optimistic_cache",
    "label": "禁用乐观缓存",
    "kind": "boolean",
    "visibleWhen": [
      {
        "key": "action",
        "op": "equals",
        "value": "resolve"
      }
    ]
  },
  {
    "key": "rewrite_ttl",
    "label": "重写 TTL",
    "kind": "number",
    "integer": true,
    "min": 0,
    "visibleWhen": [
      {
        "key": "action",
        "op": "equals",
        "value": "resolve"
      }
    ]
  },
  {
    "key": "client_subnet",
    "label": "Client subnet",
    "kind": "string",
    "visibleWhen": [
      {
        "key": "action",
        "op": "equals",
        "value": "resolve"
      }
    ]
  }
]
