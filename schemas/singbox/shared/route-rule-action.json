    "visibleWhen": [
      {
        "key": "action",
        "op": "equals",
        "value": "direct"
      },
      {
        "key": "network_strategy",
        "op": "empty"
      }
    ]
  },
  {
    "key": "bind_address_no_port",
    "label": "绑定地址不含端口",
    "kind": "boolean",
    "visibleWhen": [
      {
        "key": "action",
        "op": "equals",
        "value": "direct"
