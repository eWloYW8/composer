    "kind": "boolean",
    "visibleWhen": [
      {
        "key": "action",
        "op": "equals",
        "value": "direct"
      }
    ]
  },
  {
    "key": "disable_tcp_keep_alive",
    "label": "禁用 TCP keepalive",
    "kind": "boolean",
    "visibleWhen": [
      {
        "key": "action",
        "op": "equals",
        "value": "direct"
      }
    ]
  },
  {
    "key": "tcp_keep_alive",
    "label": "TCP keepalive",
    "kind": "string",
    "visibleWhen": [
      {
        "key": "action",
        "op": "equals",
        "value": "direct"
      }
    ]
  },
  {
    "key": "tcp_keep_alive_interval",
    "label": "TCP keepalive 间隔",
    "kind": "string",
    "visibleWhen": [
