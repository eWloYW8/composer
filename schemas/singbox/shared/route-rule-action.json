[
  {
    "key": "action",
    "label": "动作",
    "kind": "select",
    "required": true,
    "defaultValue": "route",
    "options": [
      "route",
      "bypass",
      "direct",
      "reject",
      "hijack-dns",
      "route-options",
      "sniff",
      "resolve"
    ]
  },
  {
    "key": "_route_options_requires_any",
    "label": "route-options 至少需要填写一个路由选项",
    "kind": "constraint",
    "requiresAny": [
      "override_address",
      "override_port",
      "network_strategy",
      "fallback_delay",
      "udp_disable_domain_unmapping",
      "udp_connect",
      "udp_timeout",
      "tls_fragment",
      "tls_record_fragment",
      "tls_spoof"
    ],
    "visibleWhen": [
      {
        "key": "action",
        "op": "equals",
        "value": "route-options"
      }
    ]
  },
  {
    "key": "outbound",
    "label": "出站",
    "kind": "string",
    "required": true,
    "visibleWhen": [
      {
        "key": "action",
        "op": "equals",
        "value": "route"
      }
    ]
  },
  {
    "key": "outbound",
    "label": "出站",
    "kind": "string",
    "visibleWhen": [
      {
        "key": "action",
        "op": "equals",
        "value": "bypass"
      }
    ]
  },
  {
    "key": "override_address",
    "label": "覆盖目标地址",
    "kind": "string",
    "visibleWhen": [
      {
        "key": "action",
        "op": "one-of",
        "values": ["route", "bypass", "route-options"]
      }
    ]
  },
  {
    "key": "override_port",
    "label": "覆盖目标端口",
    "kind": "number",
    "integer": true,
    "min": 0,
    "max": 65535,
    "visibleWhen": [
      {
        "key": "action",
        "op": "one-of",
        "values": ["route", "bypass", "route-options"]
      }
    ]
  },
  {
    "key": "network_strategy",
    "label": "网络策略",
    "kind": "select",
    "options": ["", "default", "fallback", "hybrid"],
    "visibleWhen": [
      {
        "key": "action",
        "op": "one-of",
        "values": ["route", "bypass", "route-options"]
      }
    ]
  },
  {
    "key": "fallback_delay",
    "label": "fallback delay",
    "kind": "number",
    "integer": true,
    "min": 0,
    "visibleWhen": [
      {
        "key": "action",
        "op": "one-of",
        "values": ["route", "bypass", "route-options"]
      }
    ]
  },
  {
    "key": "udp_disable_domain_unmapping",
    "label": "UDP 禁用域名反映射",
    "kind": "boolean",
    "visibleWhen": [
      {
        "key": "action",
        "op": "one-of",
        "values": ["route", "bypass", "route-options"]
      }
    ]
  },
  {
    "key": "udp_connect",
    "label": "UDP connect",
    "kind": "boolean",
    "visibleWhen": [
      {
        "key": "action",
        "op": "one-of",
        "values": ["route", "bypass", "route-options"]
      }
    ]
  },
  {
    "key": "udp_timeout",
    "label": "UDP 超时",
    "kind": "string",
    "visibleWhen": [
      {
        "key": "action",
        "op": "one-of",
        "values": ["route", "bypass", "route-options"]
      }
    ]
  },
  {
    "key": "tls_fragment",
    "label": "TLS 分片",
    "kind": "boolean",
    "visibleWhen": [
      {
        "key": "action",
        "op": "one-of",
        "values": ["route", "bypass", "route-options"]
      },
      {
        "key": "tls_record_fragment",
        "op": "empty"
      }
    ]
  },
  {
    "key": "tls_fragment_fallback_delay",
    "label": "TLS 分片 fallback delay",
    "kind": "string",
    "visibleWhen": [
      {
        "key": "action",
        "op": "one-of",
        "values": ["route", "bypass", "route-options"]
      },
      {
        "key": "tls_fragment",
        "op": "present"
      }
    ]
  },
  {
    "key": "tls_record_fragment",
    "label": "TLS record 分片",
    "kind": "boolean",
    "visibleWhen": [
      {
        "key": "action",
        "op": "one-of",
        "values": ["route", "bypass", "route-options"]
      },
      {
        "key": "tls_fragment",
        "op": "empty"
      }
    ]
  },
  {
    "key": "tls_spoof",
    "label": "TLS spoof SNI",
    "kind": "string",
    "visibleWhen": [
      {
        "key": "action",
        "op": "one-of",
        "values": ["route", "bypass", "route-options"]
      }
    ]
  },
  {
    "key": "tls_spoof_method",
    "label": "TLS spoof method",
    "kind": "select",
    "options": [
      "",
      "wrong-sequence",
      "wrong-checksum",
      "wrong-ack",
      "wrong-md5",
      "wrong-timestamp"
    ],
    "visibleWhen": [
      {
        "key": "action",
        "op": "one-of",
        "values": ["route", "bypass", "route-options"]
      },
      {
        "key": "tls_spoof",
        "op": "present"
      }
    ]
  },
  {
    "key": "bind_interface",
    "label": "绑定接口",
    "kind": "string",
    "visibleWhen": [
      {
        "key": "action",
        "op": "equals",
        "value": "direct"
      },
      {
        "key": "network_strategy",
        "op": "empty"
      }
    ]
  },
  {
    "key": "inet4_bind_address",
    "label": "IPv4 绑定地址",
