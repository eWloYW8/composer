      {
        "key": "detour",
        "op": "empty"
      },
      {
        "key": "bind_interface",
        "op": "empty"
      },
      {
        "key": "inet4_bind_address",
        "op": "empty"
      },
      {
        "key": "inet6_bind_address",
        "op": "empty"
      }
    ]
  },
  {
    "key": "network_type",
    "label": "网络类型",
    "kind": "string-list",
    "allowedValues": ["wifi", "cellular", "ethernet", "other"],
    "visibleWhen": [
      {
        "key": "detour",
        "op": "empty"
      }
    ]
  },
  {
    "key": "fallback_network_type",
    "label": "fallback 网络类型",
    "kind": "string-list",
    "allowedValues": ["wifi", "cellular", "ethernet", "other"],
    "visibleWhen": [
      {
        "key": "detour",
        "op": "empty"
      },
      {
        "key": "network_strategy",
        "op": "equals",
        "value": "fallback"
      }
    ]
  },
  {
    "key": "fallback_delay",
    "label": "fallback delay",
    "kind": "string",
    "visibleWhen": [
      {
        "key": "detour",
        "op": "empty"
      }
    ]
  },
  {
    "key": "domain_strategy",
    "label": "domain_strategy",
    "kind": "select",
    "options": [
      "",
      "as_is",
      "prefer_ipv4",
      "prefer_ipv6",
      "ipv4_only",
      "ipv6_only"
    ],
    "visibleWhen": [
      {
        "key": "detour",
        "op": "empty"
      }
    ]
  }
