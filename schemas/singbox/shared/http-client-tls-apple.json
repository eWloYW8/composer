[
  {
    "key": "server_name",
    "label": "Server Name",
    "kind": "string"
  },
  {
    "key": "insecure",
    "label": "跳过证书验证",
    "kind": "boolean"
  },
  {
    "key": "min_version",
    "label": "最低 TLS 版本",
    "kind": "select",
    "options": ["", "1.0", "1.1", "1.2", "1.3"]
  },
  {
    "key": "max_version",
    "label": "最高 TLS 版本",
    "kind": "select",
    "options": ["", "1.0", "1.1", "1.2", "1.3"]
  },
  {
    "key": "certificate",
    "label": "证书",
    "kind": "string-list",
    "wide": true,
    "visibleWhen": [
      {
        "key": "certificate_public_key_sha256",
        "op": "empty"
      }
    ]
  },
  {
    "key": "certificate_path",
    "label": "证书路径",
    "kind": "string",
    "visibleWhen": [
      {
        "key": "certificate_public_key_sha256",
        "op": "empty"
      }
    ]
  },
  {
    "key": "certificate_public_key_sha256",
    "label": "证书公钥 SHA256",
    "kind": "string-list",
    "visibleWhen": [
      {
        "key": "certificate",
        "op": "empty"
      },
      {
        "key": "certificate_path",
        "op": "empty"
      }
    ]
  }
]
